# Copy to .env and fill locally (never commit real secrets)

# GoHighLevel Private Integration (Wunder Real Estate / DTS)
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# SignNow (AOC / JV / Amendment sends from Contract Tracker)
SIGNNOW_ACCESS_TOKEN=
SIGNNOW_API_BASE=https://api.signnow.com
SIGNNOW_FROM_EMAIL=brandon@wunderhausgroup.com

# Railway (Operating Costs)
# Prefer an Account token (railway.com/account/tokens → "No workspace") for live invoice $.
# Project tokens also work: they estimate $ from CPU/RAM/egress/disk usage.
RAILWAY_API_TOKEN=
# Required for Workspace-scoped Bearer tokens (optional for Account tokens)
RAILWAY_WORKSPACE_ID=
