# Optional Cloudflare R2 mirror (local disk is always used as primary serve path).
# Create bucket at dash.cloudflare.com → R2 → Create bucket.
# Generate API token: R2 → Manage R2 API Tokens → Object Read & Write.
#
# Cost (2026): ~$0.015/GB-month storage, zero egress fees — ideal for property thumbnails.
# Compare AWS S3: ~$0.023/GB-month + egress ~$0.09/GB (only use S3 if already on AWS).

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET=property-imagery

# Optional: public custom domain for R2 (e.g. https://imgs.yourdomain.com)
# If set, r2Url is stored alongside local /api/cached-imagery/ URLs.
R2_PUBLIC_URL=

# Google Maps key (alternative to maps-api-key.txt)
MAPS_API_KEY=