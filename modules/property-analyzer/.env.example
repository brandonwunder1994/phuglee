# Property Distress Analyzer — copy to .env and fill in values
# Point at legacy Property Distress Analyzer imagery cache if migrating to Distress OS
PDA_IMAGERY_ROOT=
MAPS_API_KEY=
GEMINI_API_KEY=
PDA_AUTH_TOKEN=

# Offsite session backup (optional — defaults to OneDrive/PropertyDistressAnalyzer-backups)
PDA_OFFSITE_ENABLED=1
PDA_OFFSITE_DIR=

# Optional R2 imagery mirror (see .env.imagery.example)