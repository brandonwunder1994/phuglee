{
  "version": 2,
  "installCommand": "npm install && npm install --prefix modules/property-analyzer --omit=dev",
  "buildCommand": "",
  "cleanUrls": true,
  "functions": {
    "api/server.js": {
      "maxDuration": 60,
      "includeFiles": "modules/property-analyzer/**,modules/form-forge/data/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server" },
    { "source": "/forge", "destination": "/api/server" },
    { "source": "/forge/(.*)", "destination": "/api/server" },
    { "source": "/analyzer", "destination": "/api/server" },
    { "source": "/analyzer/(.*)", "destination": "/api/server" },
    { "source": "/command", "destination": "/command.html" },
    { "source": "/heat", "destination": "/heat.html" },
    { "source": "/collect", "destination": "/collect.html" },
    { "source": "/bridge", "destination": "/bridge.html" },
    { "source": "/vault", "destination": "/vault.html" }
  ]
}